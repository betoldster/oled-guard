[Desktop Entry]
Version=1.1
Type=Application
Name=OLED Guard
GenericName=OLED Burn-in Protection
Comment=Trigger a fullscreen blackout to protect OLED screens from burn-in
Icon=oled-guard
Categories=System;Utility;
Keywords=oled;burn-in;screensaver;blackout;screen;monitor;
Terminal=false
Exec=sh -c 'python3 ~/.config/oled-guard/blackout.py'

Actions=start;stop;restart;status;logs;

[Desktop Action start]
Name=Start Service
Exec=sh -c '~/.config/oled-guard/oled-guard-term.sh --wait "systemctl --user start oled-guard; echo; systemctl --user status oled-guard --no-pager"'

[Desktop Action stop]
Name=Stop Service
Exec=sh -c '~/.config/oled-guard/oled-guard-term.sh --wait "systemctl --user stop oled-guard; echo; systemctl --user status oled-guard --no-pager"'

[Desktop Action restart]
Name=Restart Service
Exec=sh -c '~/.config/oled-guard/oled-guard-term.sh --wait "systemctl --user restart oled-guard; echo; systemctl --user status oled-guard --no-pager"'

[Desktop Action status]
Name=Show Status
Exec=sh -c '~/.config/oled-guard/oled-guard-term.sh --wait "systemctl --user status oled-guard --no-pager"'

[Desktop Action logs]
Name=View Live Logs
Exec=sh -c '~/.config/oled-guard/oled-guard-term.sh "journalctl --user -u oled-guard -f"'
